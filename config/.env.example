# ================================================================
#  Databricks Genie Chatbot — Credentials File
#  STEP: Copy this file, rename it to .env, fill in your values
# ================================================================

# 1. Your Databricks workspace URL
#    HOW TO GET: Open Databricks in browser
#                Copy everything up to .com or .net
#    EXAMPLE:    https://adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# 2. Your Databricks Personal Access Token
#    HOW TO GET: Databricks → top-right icon → Settings
#                → Developer → Access Tokens → Generate New Token
#    EXAMPLE:    dapi1a2b3c4d5e6f7g8h9i0j
DATABRICKS_TOKEN=dapi_your_token_here

# 3. Your Genie Space ID
#    HOW TO GET: Open your Genie Space in Databricks
#                Look at the browser URL — copy string between last / and ?
#    URL LOOKS LIKE: .../genie/spaces/01abc123def456?o=789
#    COPY THIS PART:              01abc123def456
GENIE_SPACE_ID=your_genie_space_id_here

# 4. A display name for your chatbot (shown in the UI)
CHATBOT_NAME=NYC Taxi Analytics Assistant
